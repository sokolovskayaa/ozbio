# Скопируйте в .env для локальной разработки (файл .env не коммитится).

PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=ozbio

# testing — демо/стенд; production — боевые данные (без автосида)
APP_DB_SCHEMA=testing
LIQUIBASE_CONTEXTS=demo

SPRING_DATASOURCE_USERNAME=ozbio
SPRING_DATASOURCE_PASSWORD=ozbio

