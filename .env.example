# Локальная разработка (Spring не читает .env автоматически — export вручную или через IDE)
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=ozbio
APP_DB_SCHEMA=public
SPRING_DATASOURCE_USERNAME=ozbio
SPRING_DATASOURCE_PASSWORD=ozbio

# Docker: PG_PORT=5433 и mvn spring-boot:run -Dspring-boot.run.profiles=docker
